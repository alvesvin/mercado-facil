{
  "expo": {
    "name": "Mercado Fácil",
    "slug": "mercado-facil",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mercado-facil",
    "userInterfaceStyle": "automatic",
    "updates": {
      "url": "<https://u.expo.dev/><id>",
      "enableBsdiffPatchSupport": true
    },
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "br.com.mercado-facil",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Necessário para scanear códigos de barras",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "br.com.mercado-facil",
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "buildReactNativeFromSource": true,
          "useHermesV1": true
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow $(PRODUCT_NAME) to access your location"
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Necessário para scanear códigos de barras",
          "enableCodeScanner": true,
          "enableMicrophonePermission": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Necessário para adicionar fotos ao produto",
          "colors": {
            "cropToolbarColor": "#000000"
          },
          "dark": {
            "colors": {
              "cropToolbarColor": "#000000"
            }
          }
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ba85a300-e32e-4412-9690-33ea85458e38"
      }
    },
    "owner": "alvesvin"
  }
}
