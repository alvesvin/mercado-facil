{
  "typescript.experimental.useTsgo": true,
  "editor.indentSize": 2,
  "editor.useTabStops": false,
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "*.tsx": "${capture}View.tsx,${capture}View.test.tsx,${capture}Logic.ts,${capture}Logic.test.ts,${capture}Form.tsx,${capture}Form.test.tsx",
    "*.ts": "${capture}.test.ts"
  }
}
